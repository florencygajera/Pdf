# ── PDF Extraction Service — Environment Config ─────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.

# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-a-strong-random-secret
API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# File Limits
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=/tmp/pdf_uploads
OUTPUT_DIR=/tmp/pdf_outputs

# ── OCR Settings ─────────────────────────────────────────────────────────────
# DPI for rendering PDF pages to images before OCR.
# For Gujarati: minimum 150, recommended 200-250 for accurate matras/vowel marks.
# Higher DPI = better accuracy but slower. Capped automatically for large docs.
OCR_DPI=200

# Primary OCR language.
# Set to 'gu' to route ALL scanned pages through Tesseract (Gujarati mode).
# Set to 'en' to use PaddleOCR instead.
# This is the most important setting for Gujarati PDFs.
OCR_LANGUAGE=gu

# Ordered list of OCR languages (first entry = primary).
# Must include 'gu' for Gujarati documents.
OCR_LANGUAGES=["gu","en"]

# Tesseract executable path.
# Linux/Mac: leave unset — tesseract is found via PATH automatically.
# Windows: set to the full path if not in PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Tesseract data directory (optional, usually auto-detected).
# Linux:   /usr/share/tesseract-ocr/4.00/tessdata  (or similar)
# Windows: C:\Program Files\Tesseract-OCR\tessdata
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# Confidence threshold for accepting OCR word results.
# Gujarati model produces scores 0.15–0.60 for valid text.
# MUST be ≤ 0.3 for Gujarati. Do not raise above 0.35.
OCR_CONFIDENCE_THRESHOLD=0.3

# GPU acceleration (requires CUDA + paddle-gpu build).
OCR_USE_GPU=false

# Warm up PaddleOCR on startup. Keep false unless you have spare RAM.
OCR_PREWARM_ON_STARTUP=false

# ── Digital Extraction ────────────────────────────────────────────────────────
# Fraction of page area covered by text to classify as "digital" vs "scanned".
# 0.01 is correct for most Gujarati government scans (fully scanned = 0 coverage).
DIGITAL_TEXT_THRESHOLD=0.01

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Hard task time limit in seconds.
# PaddleOCR or Tesseract on 6 scanned pages can take 60-120s.
# Keep at 300 minimum.
CELERY_TASK_TIMEOUT=300

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text   # 'json' for production, 'text' for dev

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_EXTRACT=60/minute
RESULT_EXPIRES_SECONDS=86400
