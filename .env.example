# ── PDF Extraction Service — Environment Config ─────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.

# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-a-strong-random-secret
API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# File Limits
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=/tmp/pdf_uploads
OUTPUT_DIR=/tmp/pdf_outputs

# OCR
OCR_DPI=150
OCR_LANGUAGE=gu
OCR_LANGUAGES=["gu"]
OCR_USE_GPU=false
OCR_PREWARM_ON_STARTUP=false
OCR_CONFIDENCE_THRESHOLD=0.6

# Digital Extraction
DIGITAL_TEXT_THRESHOLD=0.05

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_TIMEOUT=1800

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text   # 'json' for production, 'text' for dev

# Rate Limits
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_EXTRACT=60/minute
RESULT_EXPIRES_SECONDS=86400
